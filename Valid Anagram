class hello{
    public boolean isAnagram(String s, String t) {
     if (s.length() != t.length()) {
            return false;
        }

        char[] st0 = s.toCharArray();
        char[] st1 = t.toCharArray();

        Arrays.sort(st0);
        Arrays.sort(st1);

        return Arrays.equals(st0, st1);
    }
}
